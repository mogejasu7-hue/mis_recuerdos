<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mis Recuerdos</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0a06;
    --bg2: #1c1208;
    --bg3: #261a0d;
    --border: #3d2b14;
    --accent: #c9833a;
    --accent2: #8b5e2a;
    --gold: #e8c97a;
    --cream: #f0e3c8;
    --cream2: #c8b89a;
    --rose: #c17a6f;
    --text: #f0e3c8;
    --text2: #a89070;
    --success: #5a9c6a;
    --danger: #c0504a;
    --shadow: rgba(0,0,0,0.6);
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'Lato', Arial, sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 18px;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── GRAIN OVERLAY ─────────────────────────────────────────── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ── LAYOUT ──────────────────────────────────────────────── */
  .app { display: flex; height: 100vh; }

  /* ── SIDEBAR ─────────────────────────────────────────────── */
  .sidebar {
    width: 280px;
    min-width: 280px;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow-y: auto;
  }

  .sidebar-header {
    padding: 32px 24px 24px;
    border-bottom: 1px solid var(--border);
    text-align: center;
  }

  .sidebar-logo {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--gold);
    letter-spacing: 0.5px;
    line-height: 1.2;
  }

  .sidebar-logo span {
    font-style: italic;
    color: var(--accent);
  }

  .sidebar-tagline {
    font-size: 0.78rem;
    color: var(--text2);
    margin-top: 6px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .sidebar-nav {
    flex: 1;
    padding: 20px 0;
  }

  .nav-section {
    padding: 8px 20px 4px;
    font-size: 0.7rem;
    color: var(--text2);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 24px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.2s;
    font-size: 1rem;
    color: var(--cream2);
  }

  .nav-item:hover { background: var(--bg3); color: var(--cream); }
  .nav-item.active {
    background: var(--bg3);
    border-left-color: var(--accent);
    color: var(--gold);
  }

  .nav-item .icon { font-size: 1.3rem; width: 28px; text-align: center; }

  .sidebar-footer {
    padding: 20px 24px;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text2);
    text-align: center;
  }

  /* ── MAIN ────────────────────────────────────────────────── */
  .main {
    flex: 1;
    overflow-y: auto;
    background: var(--bg);
  }

  .page { display: none; padding: 40px 48px; }
  .page.active { display: block; }

  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 2.2rem;
    color: var(--gold);
  }

  .page-subtitle {
    font-size: 0.9rem;
    color: var(--text2);
    margin-top: 4px;
  }

  /* ── BUTTONS ─────────────────────────────────────────────── */
  .btn {
    padding: 12px 28px;
    border: none;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .btn-primary {
    background: var(--accent);
    color: #0f0a06;
  }
  .btn-primary:hover { background: var(--gold); }

  .btn-secondary {
    background: transparent;
    color: var(--cream2);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--cream); }

  .btn-danger {
    background: var(--danger);
    color: #fff;
  }
  .btn-danger:hover { background: #a03030; }

  .btn-sm { padding: 8px 18px; font-size: 0.85rem; }
  .btn-icon { padding: 8px 12px; font-size: 1.1rem; }

  /* ── HOME DASHBOARD ──────────────────────────────────────── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 40px;
  }

  .stat-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px;
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2.8rem;
    color: var(--accent);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text2);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 6px;
  }

  .decades-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--cream);
    margin-bottom: 20px;
  }

  .decades-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }

  .decade-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 24px 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }

  .decade-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.2s;
  }

  .decade-card:hover { border-color: var(--accent); background: var(--bg3); }
  .decade-card:hover::before { transform: scaleX(1); }

  .decade-year {
    font-family: var(--font-display);
    font-size: 1.8rem;
    color: var(--gold);
    font-style: italic;
  }

  .decade-count {
    font-size: 0.85rem;
    color: var(--text2);
    margin-top: 4px;
  }

  /* ── MEMORIES GALLERY ────────────────────────────────────── */
  .filters-row {
    display: flex;
    gap: 14px;
    margin-bottom: 28px;
    flex-wrap: wrap;
    align-items: center;
  }

  .search-input {
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 18px;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 1rem;
    flex: 1;
    min-width: 200px;
    outline: none;
  }

  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--text2); }

  select.filter-select {
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 18px;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    cursor: pointer;
  }

  select.filter-select:focus { border-color: var(--accent); }

  .memories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  /* ── MEMORY CARD ─────────────────────────────────────────── */
  .memory-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
  }

  .memory-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px var(--shadow);
  }

  /* Vintage corner decorations */
  .memory-card::before, .memory-card::after {
    content: '';
    position: absolute;
    width: 20px; height: 20px;
    border-color: var(--accent2);
    border-style: solid;
    opacity: 0.5;
    z-index: 2;
    transition: opacity 0.2s;
  }
  .memory-card::before { top: 8px; left: 8px; border-width: 2px 0 0 2px; }
  .memory-card::after  { bottom: 8px; right: 8px; border-width: 0 2px 2px 0; }
  .memory-card:hover::before, .memory-card:hover::after { opacity: 1; }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    filter: sepia(20%) contrast(1.05);
    transition: filter 0.3s;
  }

  .memory-card:hover .card-image { filter: sepia(0%) contrast(1.1); }

  .card-no-image {
    width: 100%;
    height: 200px;
    background: var(--bg3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: var(--border);
  }

  .card-body { padding: 20px; }

  .card-decade {
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--cream);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.88rem;
    color: var(--text2);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    gap: 12px;
    margin-top: 14px;
    flex-wrap: wrap;
  }

  .card-tag {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text2);
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 0.78rem;
  }

  /* ── FORMS ───────────────────────────────────────────────── */
  .form-wrapper {
    max-width: 800px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .form-group { margin-bottom: 24px; }
  .form-group.full { grid-column: 1 / -1; }

  label {
    display: block;
    font-size: 0.82rem;
    color: var(--text2);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
    font-weight: 700;
  }

  input[type="text"], input[type="date"], textarea, select {
    width: 100%;
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 14px 16px;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  input:focus, textarea:focus, select:focus { border-color: var(--accent); }
  ::placeholder { color: var(--text2); }

  textarea { resize: vertical; min-height: 120px; }

  .file-drop {
    border: 2px dashed var(--border);
    border-radius: 8px;
    padding: 40px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--bg2);
  }

  .file-drop:hover, .file-drop.drag-over {
    border-color: var(--accent);
    background: var(--bg3);
  }

  .file-drop-icon { font-size: 2.5rem; margin-bottom: 12px; }
  .file-drop-text { color: var(--text2); font-size: 0.95rem; }
  .file-drop-text strong { color: var(--accent); }

  .file-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .file-preview-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .file-preview-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: sepia(20%);
  }

  .file-preview-remove {
    position: absolute;
    top: 4px; right: 4px;
    background: var(--danger);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 22px; height: 22px;
    font-size: 0.75rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }

  .people-selector {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 8px;
  }

  .person-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 8px 16px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.9rem;
    color: var(--cream2);
  }

  .person-chip.selected {
    background: var(--accent2);
    border-color: var(--accent);
    color: var(--cream);
  }

  .form-actions {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  /* ── MODAL ───────────────────────────────────────────────── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 40px;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
  }

  .modal-close {
    position: absolute;
    top: 20px; right: 20px;
    background: none;
    border: none;
    color: var(--text2);
    font-size: 1.4rem;
    cursor: pointer;
    line-height: 1;
  }
  .modal-close:hover { color: var(--cream); }

  .modal-images {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  .modal-image {
    width: 100%; aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 4px;
    cursor: pointer;
    transition: transform 0.2s;
    filter: sepia(15%);
  }
  .modal-image:hover { transform: scale(1.02); filter: sepia(0%); }

  .modal-decade {
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 1.9rem;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .modal-desc {
    color: var(--cream2);
    line-height: 1.8;
    font-size: 1rem;
    margin-bottom: 20px;
    white-space: pre-wrap;
  }

  .modal-info {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    margin-bottom: 16px;
  }

  .modal-info-item { font-size: 0.9rem; color: var(--text2); }
  .modal-info-item strong { color: var(--cream); display: block; }

  .modal-people {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .modal-person-tag {
    background: var(--bg3);
    border: 1px solid var(--accent2);
    color: var(--cream2);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
  }

  .modal-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  /* ── LIGHTBOX ────────────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.95);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .lightbox.open { display: flex; }
  .lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 4px;
  }
  .lightbox-close {
    position: absolute;
    top: 24px; right: 32px;
    background: none; border: none;
    color: #fff; font-size: 2rem;
    cursor: pointer;
  }

  /* ── PERSONAS PAGE ───────────────────────────────────────── */
  .personas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .persona-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px;
    text-align: center;
    transition: all 0.2s;
  }

  .persona-card:hover { border-color: var(--accent); }

  .persona-avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: var(--bg3);
    border: 2px solid var(--accent2);
    margin: 0 auto 16px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem;
    color: var(--accent);
  }

  .persona-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: sepia(20%);
  }

  .persona-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--cream);
    margin-bottom: 6px;
  }

  .persona-desc {
    font-size: 0.88rem;
    color: var(--text2);
    line-height: 1.5;
  }

  .persona-count {
    margin-top: 12px;
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 1px;
  }

  .persona-actions {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 16px;
  }

  /* ── TOAST ───────────────────────────────────────────────── */
  .toast-container {
    position: fixed;
    bottom: 32px; right: 32px;
    z-index: 9000;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .toast {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    color: var(--cream);
    padding: 14px 20px;
    border-radius: 6px;
    font-size: 0.95rem;
    min-width: 280px;
    box-shadow: 0 4px 20px var(--shadow);
    animation: slideIn 0.3s ease;
  }

  .toast.success { border-left-color: var(--success); }
  .toast.error   { border-left-color: var(--danger); }

  @keyframes slideIn {
    from { transform: translateX(40px); opacity: 0; }
    to   { transform: translateX(0); opacity: 1; }
  }

  /* ── LOADING ─────────────────────────────────────────────── */
  .loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px;
    color: var(--text2);
    font-size: 1.1rem;
    gap: 14px;
  }

  .spinner {
    width: 28px; height: 28px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .empty-state {
    text-align: center;
    padding: 80px 40px;
    color: var(--text2);
  }

  .empty-state-icon { font-size: 4rem; margin-bottom: 16px; }
  .empty-state h3 { font-family: var(--font-display); font-size: 1.5rem; color: var(--cream2); margin-bottom: 8px; }

  /* ── RESPONSIVE / TV ADJUSTMENTS ─────────────────────────── */
  @media (min-width: 1400px) {
    body { font-size: 20px; }
    .sidebar { width: 300px; min-width: 300px; }
    .page { padding: 48px 64px; }
    .memories-grid { grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); }
  }

  @media (max-width: 900px) {
    .app { flex-direction: column; }
    .sidebar { width: 100%; min-width: unset; height: auto; }
    .sidebar-nav { display: flex; flex-direction: row; overflow-x: auto; padding: 0; }
    .nav-item { flex-direction: column; gap: 4px; font-size: 0.75rem; padding: 12px 16px; text-align: center; }
    .page { padding: 24px 20px; }
    .form-grid { grid-template-columns: 1fr; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── UPLOAD PROGRESS ─────────────────────────────────────── */
  .upload-progress {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    margin-top: 8px;
    overflow: hidden;
  }

  .upload-progress-bar {
    height: 100%;
    background: var(--accent);
    transition: width 0.3s;
    width: 0%;
  }

  /* ── IMAGEN PRINCIPAL GRANDE ─────────────────────────────── */
  .main-image-big {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 20px;
    filter: sepia(15%);
  }

  .no-memories-msg {
    text-align: center;
    padding: 60px;
    color: var(--text2);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.2rem;
  }
</style>
</head>
<body>

<div class="app">
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">Mis<br><span>Recuerdos</span></div>
      <div class="sidebar-tagline">Archivo personal</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Principal</div>
      <div class="nav-item active" data-page="home">
        <span class="icon">🏠</span> Inicio
      </div>
      <div class="nav-item" data-page="galeria">
        <span class="icon">📸</span> Galería
      </div>
      <div class="nav-item" data-page="nuevo">
        <span class="icon">✨</span> Añadir recuerdo
      </div>
      <div class="nav-section">Gestión</div>
      <div class="nav-item" data-page="personas">
        <span class="icon">👥</span> Personas
      </div>
      <div class="nav-item" data-page="nueva-persona">
        <span class="icon">➕</span> Añadir persona
      </div>
    </nav>
    <div class="sidebar-footer">
      Solo tuyo · Solo tuyo · Solo tuyo
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">

    <!-- HOME -->
    <section class="page active" id="page-home">
      <div class="page-header">
        <div>
          <h1 class="page-title">Bienvenida, Gema ✨</h1>
          <p class="page-subtitle">Tu archivo personal de recuerdos</p>
        </div>
        <button class="btn btn-primary" onclick="goTo('nuevo')">+ Añadir recuerdo</button>
      </div>

      <div class="stats-row" id="stats-row">
        <div class="stat-card">
          <div class="stat-number" id="stat-total">—</div>
          <div class="stat-label">Recuerdos</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" id="stat-fotos">—</div>
          <div class="stat-label">Fotos</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" id="stat-personas">—</div>
          <div class="stat-label">Personas</div>
        </div>
        <div class="stat-card">
          <div class="stat-number" id="stat-decadas">—</div>
          <div class="stat-label">Décadas</div>
        </div>
      </div>

      <h2 class="decades-title">Explorar por décadas</h2>
      <div class="decades-grid" id="decades-grid">
        <div class="loading"><div class="spinner"></div> Cargando...</div>
      </div>

      <h2 class="decades-title" style="margin-top:20px;">Recuerdos recientes</h2>
      <div class="memories-grid" id="recent-grid">
        <div class="loading"><div class="spinner"></div> Cargando...</div>
      </div>
    </section>

    <!-- GALERÍA -->
    <section class="page" id="page-galeria">
      <div class="page-header">
        <div>
          <h1 class="page-title">Galería</h1>
          <p class="page-subtitle">Todos tus recuerdos</p>
        </div>
        <button class="btn btn-primary" onclick="goTo('nuevo')">+ Añadir</button>
      </div>
      <div class="filters-row">
        <input type="text" class="search-input" id="search-input" placeholder="Buscar recuerdos..." oninput="filterMemories()">
        <select class="filter-select" id="filter-decada" onchange="filterMemories()">
          <option value="">Todas las décadas</option>
        </select>
      </div>
      <div class="memories-grid" id="galeria-grid">
        <div class="loading"><div class="spinner"></div> Cargando...</div>
      </div>
    </section>

    <!-- NUEVO RECUERDO -->
    <section class="page" id="page-nuevo">
      <div class="page-header">
        <div>
          <h1 class="page-title" id="nuevo-title">Nuevo recuerdo</h1>
          <p class="page-subtitle">Guarda este momento para siempre</p>
        </div>
      </div>
      <div class="form-wrapper">
        <div class="form-grid">
          <div class="form-group">
            <label>Título *</label>
            <input type="text" id="mem-titulo" placeholder="Un verano en la playa...">
          </div>
          <div class="form-group">
            <label>Década</label>
            <select id="mem-decada">
              <option value="">Sin especificar</option>
              <option>Años 40</option>
              <option>Años 50</option>
              <option>Años 60</option>
              <option>Años 70</option>
              <option>Años 80</option>
              <option>Años 90</option>
              <option>Años 2000</option>
              <option>Años 2010</option>
              <option>Años 2020</option>
            </select>
          </div>
          <div class="form-group">
            <label>Fecha aproximada</label>
            <input type="text" id="mem-fecha" placeholder="Verano de 1975, Navidad 1982...">
          </div>
          <div class="form-group">
            <label>Lugar</label>
            <input type="text" id="mem-lugar" placeholder="Valencia, pueblo de la abuela...">
          </div>
          <div class="form-group full">
            <label>Historia y recuerdos</label>
            <textarea id="mem-desc" rows="5" placeholder="Cuéntame todo sobre este momento..."></textarea>
          </div>
          <div class="form-group full">
            <label>Personas en este recuerdo</label>
            <div class="people-selector" id="people-selector">
              <span style="color:var(--text2);font-size:0.9rem;">Primero añade personas desde el menú 👥</span>
            </div>
          </div>
          <div class="form-group full">
            <label>Fotos y vídeos</label>
            <div class="file-drop" id="file-drop" onclick="document.getElementById('file-input').click()">
              <div class="file-drop-icon">📷</div>
              <div class="file-drop-text">
                <strong>Haz clic aquí</strong> para subir fotos o vídeos<br>
                <small style="opacity:0.7;">JPG, PNG, HEIC, MP4 · Puedes seleccionar varias a la vez</small>
              </div>
            </div>
            <input type="file" id="file-input" accept="image/*,video/*" multiple style="display:none" onchange="handleFiles(this.files)">
            <div class="upload-progress" id="upload-progress" style="display:none">
              <div class="upload-progress-bar" id="upload-bar"></div>
            </div>
            <div class="file-preview-grid" id="file-preview"></div>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" id="save-btn" onclick="saveMemory()">💾 Guardar recuerdo</button>
          <button class="btn btn-secondary" onclick="resetForm(); goTo('galeria')">Cancelar</button>
        </div>
      </div>
    </section>

    <!-- PERSONAS -->
    <section class="page" id="page-personas">
      <div class="page-header">
        <div>
          <h1 class="page-title">Personas</h1>
          <p class="page-subtitle">Las personas que aparecen en tus recuerdos</p>
        </div>
        <button class="btn btn-primary" onclick="goTo('nueva-persona')">+ Añadir persona</button>
      </div>
      <div class="personas-grid" id="personas-grid">
        <div class="loading"><div class="spinner"></div> Cargando...</div>
      </div>
    </section>

    <!-- NUEVA PERSONA -->
    <section class="page" id="page-nueva-persona">
      <div class="page-header">
        <div>
          <h1 class="page-title" id="persona-form-title">Nueva persona</h1>
          <p class="page-subtitle">Añade a alguien especial a tu álbum</p>
        </div>
      </div>
      <div class="form-wrapper">
        <div class="form-grid">
          <div class="form-group">
            <label>Nombre completo *</label>
            <input type="text" id="per-nombre" placeholder="María García...">
          </div>
          <div class="form-group">
            <label>¿Quién es?</label>
            <input type="text" id="per-relacion" placeholder="Mi abuela, mi mejor amiga...">
          </div>
          <div class="form-group full">
            <label>Descripción</label>
            <textarea id="per-desc" rows="4" placeholder="Cuéntame algo sobre esta persona..."></textarea>
          </div>
          <div class="form-group full">
            <label>Foto de perfil</label>
            <div class="file-drop" onclick="document.getElementById('per-foto-input').click()">
              <div class="file-drop-icon">👤</div>
              <div class="file-drop-text"><strong>Subir foto</strong></div>
            </div>
            <input type="file" id="per-foto-input" accept="image/*" style="display:none" onchange="handlePersonaFoto(this.files)">
            <div id="per-foto-preview" style="margin-top:12px;"></div>
          </div>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" id="save-persona-btn" onclick="savePersona()">💾 Guardar persona</button>
          <button class="btn btn-secondary" onclick="resetPersonaForm(); goTo('personas')">Cancelar</button>
        </div>
      </div>
    </section>

  </main>
</div>

<!-- MODAL VER RECUERDO -->
<div class="modal-overlay" id="memory-modal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div id="modal-content"></div>
    <div class="modal-actions" id="modal-actions"></div>
  </div>
</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" onclick="closeLightbox()">✕</button>
  <img id="lightbox-img" src="" alt="">
</div>

<!-- TOASTS -->
<div class="toast-container" id="toasts"></div>

<script>
// ── CONFIG ────────────────────────────────────────────────────
const SUPABASE_URL = 'https://kwgydmenpeggpiehazvv.supabase.co';
const SUPABASE_KEY = 'sb_publishable_vFxgWvgdmx1uJkXNj0PiLA_OhriE2T2';
const BUCKET = 'recuerdos';

// ── STATE ─────────────────────────────────────────────────────
let allMemories = [];
let allPersonas = [];
let allArchivos = [];
let editingMemoryId = null;
let editingPersonaId = null;
let pendingFiles = []; // {file, preview, uploadedUrl}
let pendingPersonaFoto = null;
let selectedPeople = [];

// ── SUPABASE API ──────────────────────────────────────────────
async function supa(method, path, body=null, isStorage=false) {
  const base = isStorage
    ? `${SUPABASE_URL}/storage/v1`
    : `${SUPABASE_URL}/rest/v1`;

  const headers = {
    'apikey': SUPABASE_KEY,
    'Authorization': `Bearer ${SUPABASE_KEY}`,
  };
  if (!isStorage && body) headers['Content-Type'] = 'application/json';
  if (!isStorage) headers['Prefer'] = 'return=representation';

  const res = await fetch(`${base}${path}`, {
    method, headers,
    body: body ? (isStorage ? body : JSON.stringify(body)) : null,
  });
  if (!res.ok && res.status !== 204) {
    const err = await res.text();
    throw new Error(err);
  }
  if (res.status === 204) return null;
  const ct = res.headers.get('content-type') || '';
  return ct.includes('application/json') ? res.json() : res.text();
}

async function uploadFile(file, folder='') {
  const ext = file.name.split('.').pop();
  const name = `${folder}${Date.now()}_${Math.random().toString(36).slice(2)}.${ext}`;
  await supa('POST', `/object/${BUCKET}/${name}`, file, true);
  return `${SUPABASE_URL}/storage/v1/object/public/${BUCKET}/${name}`;
}

// ── NAVIGATION ────────────────────────────────────────────────
function goTo(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById(`page-${page}`).classList.add('active');
  document.querySelector(`[data-page="${page}"]`)?.classList.add('active');
  window.scrollTo(0,0);

  if (page === 'home')          loadHome();
  if (page === 'galeria')       loadGaleria();
  if (page === 'personas')      loadPersonas();
  if (page === 'nuevo')         loadPeopleSelectorInForm();
  if (page === 'nueva-persona') { resetPersonaForm(); }
}

document.querySelectorAll('.nav-item').forEach(item => {
  item.addEventListener('click', () => goTo(item.dataset.page));
});

// ── TOAST ─────────────────────────────────────────────────────
function toast(msg, type='info') {
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  document.getElementById('toasts').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

// ── LOAD HOME ─────────────────────────────────────────────────
async function loadHome() {
  try {
    const [memories, personas, archivos] = await Promise.all([
      supa('GET', '/recuerdos?select=*&order=created_at.desc'),
      supa('GET', '/personas?select=*'),
      supa('GET', '/archivos?select=*'),
    ]);
    allMemories = memories || [];
    allPersonas = personas || [];
    allArchivos = archivos || [];

    // Stats
    const decadas = [...new Set(allMemories.map(m=>m.decada).filter(Boolean))];
    document.getElementById('stat-total').textContent    = allMemories.length;
    document.getElementById('stat-fotos').textContent    = allArchivos.length;
    document.getElementById('stat-personas').textContent = allPersonas.length;
    document.getElementById('stat-decadas').textContent  = decadas.length;

    // Decades
    const decadesGrid = document.getElementById('decades-grid');
    if (decadas.length === 0) {
      decadesGrid.innerHTML = '<div class="no-memories-msg">Aún no hay recuerdos clasificados por décadas</div>';
    } else {
      decadesGrid.innerHTML = decadas.map(d => {
        const count = allMemories.filter(m=>m.decada===d).length;
        return `<div class="decade-card" onclick="filterByDecada('${d}')">
          <div class="decade-year">${d}</div>
          <div class="decade-count">${count} recuerdo${count!==1?'s':''}</div>
        </div>`;
      }).join('');
    }

    // Recent
    const recent = allMemories.slice(0,6);
    document.getElementById('recent-grid').innerHTML = recent.length
      ? recent.map(m=>renderCard(m)).join('')
      : '<div class="no-memories-msg">Aún no hay recuerdos · ¡Añade el primero! ✨</div>';

  } catch(e) {
    toast('Error cargando datos: '+e.message, 'error');
  }
}

function filterByDecada(decada) {
  goTo('galeria');
  setTimeout(() => {
    document.getElementById('filter-decada').value = decada;
    filterMemories();
  }, 100);
}

// ── RENDER CARD ───────────────────────────────────────────────
function renderCard(m) {
  const fotos = allArchivos.filter(a=>a.recuerdo_id===m.id && a.tipo==='foto');
  const portada = fotos.find(f=>f.es_portada) || fotos[0];
  const imgHtml = portada
    ? `<img class="card-image" src="${portada.url}" alt="${m.titulo}" loading="lazy">`
    : `<div class="card-no-image">📷</div>`;

  return `<div class="memory-card" onclick="openMemory('${m.id}')">
    ${imgHtml}
    <div class="card-body">
      <div class="card-decade">${m.decada || 'Sin clasificar'} ${m.fecha_aprox ? '· '+m.fecha_aprox : ''}</div>
      <div class="card-title">${m.titulo}</div>
      ${m.descripcion ? `<div class="card-desc">${m.descripcion}</div>` : ''}
      <div class="card-meta">
        ${m.lugar ? `<span class="card-tag">📍 ${m.lugar}</span>` : ''}
        ${fotos.length > 0 ? `<span class="card-tag">📸 ${fotos.length}</span>` : ''}
      </div>
    </div>
  </div>`;
}

// ── GALERÍA ───────────────────────────────────────────────────
async function loadGaleria() {
  document.getElementById('galeria-grid').innerHTML = '<div class="loading"><div class="spinner"></div> Cargando...</div>';
  try {
    const [memories, archivos] = await Promise.all([
      supa('GET', '/recuerdos?select=*&order=created_at.desc'),
      supa('GET', '/archivos?select=*'),
    ]);
    allMemories = memories || [];
    allArchivos = archivos || [];

    // Populate decade filter
    const decadas = [...new Set(allMemories.map(m=>m.decada).filter(Boolean))];
    const sel = document.getElementById('filter-decada');
    sel.innerHTML = '<option value="">Todas las décadas</option>' +
      decadas.map(d=>`<option value="${d}">${d}</option>`).join('');

    filterMemories();
  } catch(e) {
    toast('Error: '+e.message, 'error');
  }
}

function filterMemories() {
  const q     = document.getElementById('search-input')?.value.toLowerCase() || '';
  const deca  = document.getElementById('filter-decada')?.value || '';
  const filtered = allMemories.filter(m => {
    const matchQ = !q || m.titulo.toLowerCase().includes(q) ||
      (m.descripcion||'').toLowerCase().includes(q) ||
      (m.lugar||'').toLowerCase().includes(q);
    const matchD = !deca || m.decada === deca;
    return matchQ && matchD;
  });

  const grid = document.getElementById('galeria-grid');
  if (filtered.length === 0) {
    grid.innerHTML = `<div class="empty-state">
      <div class="empty-state-icon">🔍</div>
      <h3>Sin resultados</h3>
      <p>Prueba con otro término o década</p>
    </div>`;
  } else {
    grid.innerHTML = filtered.map(m=>renderCard(m)).join('');
  }
}

// ── OPEN MEMORY MODAL ─────────────────────────────────────────
async function openMemory(id) {
  const m = allMemories.find(x=>x.id===id);
  if (!m) return;

  const archivos = allArchivos.filter(a=>a.recuerdo_id===id);
  const fotos = archivos.filter(a=>a.tipo==='foto');

  // Load people
  let personas = [];
  try {
    const links = await supa('GET', `/recuerdos_personas?recuerdo_id=eq.${id}&select=persona_id`);
    const ids = (links||[]).map(l=>l.persona_id);
    personas = allPersonas.filter(p=>ids.includes(p.id));
  } catch(e){}

  const imagesHtml = fotos.length
    ? `<div class="modal-images">${fotos.map(f=>`<img class="modal-image" src="${f.url}" alt="" onclick="openLightbox('${f.url}')">`).join('')}</div>`
    : '';

  document.getElementById('modal-content').innerHTML = `
    ${imagesHtml}
    <div class="modal-decade">${m.decada||''} ${m.fecha_aprox ? '· '+m.fecha_aprox : ''}</div>
    <h2 class="modal-title">${m.titulo}</h2>
    ${m.descripcion ? `<div class="modal-desc">${m.descripcion}</div>` : ''}
    <div class="modal-info">
      ${m.lugar ? `<div class="modal-info-item"><strong>📍 Lugar</strong>${m.lugar}</div>` : ''}
      ${m.decada ? `<div class="modal-info-item"><strong>🗓️ Época</strong>${m.decada}</div>` : ''}
      <div class="modal-info-item"><strong>📸 Archivos</strong>${fotos.length} foto${fotos.length!==1?'s':''}</div>
    </div>
    ${personas.length ? `<div class="modal-people">${personas.map(p=>`<span class="modal-person-tag">👤 ${p.nombre}</span>`).join('')}</div>` : ''}
  `;

  document.getElementById('modal-actions').innerHTML = `
    <button class="btn btn-secondary btn-sm" onclick="editMemory('${id}')">✏️ Editar</button>
    <button class="btn btn-danger btn-sm" onclick="confirmDelete('${id}')">🗑️ Eliminar</button>
    <button class="btn btn-secondary btn-sm" onclick="closeModal()">Cerrar</button>
  `;

  document.getElementById('memory-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('memory-modal').classList.remove('open');
}

// ── LIGHTBOX ──────────────────────────────────────────────────
function openLightbox(url) {
  document.getElementById('lightbox-img').src = url;
  document.getElementById('lightbox').classList.add('open');
}
function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
}

// ── FILE HANDLING ─────────────────────────────────────────────
function handleFiles(files) {
  for (const file of files) {
    const reader = new FileReader();
    reader.onload = (e) => {
      pendingFiles.push({ file, preview: e.target.result, uploadedUrl: null });
      renderFilePreviews();
    };
    reader.readAsDataURL(file);
  }
}

function renderFilePreviews() {
  const grid = document.getElementById('file-preview');
  grid.innerHTML = pendingFiles.map((f, i) => `
    <div class="file-preview-item">
      <img src="${f.preview}" alt="">
      <button class="file-preview-remove" onclick="removeFile(${i})">✕</button>
    </div>
  `).join('');
}

function removeFile(i) {
  pendingFiles.splice(i, 1);
  renderFilePreviews();
}

// Drag and drop
const fileDrop = document.getElementById('file-drop');
fileDrop.addEventListener('dragover', e => { e.preventDefault(); fileDrop.classList.add('drag-over'); });
fileDrop.addEventListener('dragleave', () => fileDrop.classList.remove('drag-over'));
fileDrop.addEventListener('drop', e => {
  e.preventDefault();
  fileDrop.classList.remove('drag-over');
  handleFiles(e.dataTransfer.files);
});

// ── SAVE MEMORY ───────────────────────────────────────────────
async function saveMemory() {
  const titulo = document.getElementById('mem-titulo').value.trim();
  if (!titulo) { toast('El título es obligatorio', 'error'); return; }

  const btn = document.getElementById('save-btn');
  btn.disabled = true;
  btn.textContent = '⏳ Guardando...';

  try {
    const data = {
      titulo,
      descripcion: document.getElementById('mem-desc').value.trim() || null,
      decada:      document.getElementById('mem-decada').value || null,
      fecha_aprox: document.getElementById('mem-fecha').value.trim() || null,
      lugar:       document.getElementById('mem-lugar').value.trim() || null,
    };

    let memId;
    if (editingMemoryId) {
      await supa('PATCH', `/recuerdos?id=eq.${editingMemoryId}`, data);
      memId = editingMemoryId;
      // Remove old people links
      await supa('DELETE', `/recuerdos_personas?recuerdo_id=eq.${memId}`);
    } else {
      const res = await supa('POST', '/recuerdos', data);
      memId = res[0].id;
    }

    // People links
    if (selectedPeople.length) {
      const links = selectedPeople.map(pid => ({ recuerdo_id: memId, persona_id: pid }));
      await supa('POST', '/recuerdos_personas', links);
    }

    // Upload files
    if (pendingFiles.length) {
      const progress = document.getElementById('upload-progress');
      const bar = document.getElementById('upload-bar');
      progress.style.display = 'block';
      for (let i = 0; i < pendingFiles.length; i++) {
        const f = pendingFiles[i];
        bar.style.width = `${Math.round((i/pendingFiles.length)*100)}%`;
        const url = await uploadFile(f.file, `${memId}/`);
        const tipo = f.file.type.startsWith('video') ? 'video' : 'foto';
        await supa('POST', '/archivos', { recuerdo_id: memId, url, tipo, es_portada: i===0 });
      }
      bar.style.width = '100%';
      setTimeout(() => { progress.style.display = 'none'; bar.style.width = '0%'; }, 600);
    }

    toast(editingMemoryId ? '✅ Recuerdo actualizado' : '✅ Recuerdo guardado', 'success');
    resetForm();
    goTo('galeria');

  } catch(e) {
    toast('Error guardando: '+e.message, 'error');
    console.error(e);
  } finally {
    btn.disabled = false;
    btn.textContent = '💾 Guardar recuerdo';
  }
}

function resetForm() {
  editingMemoryId = null;
  pendingFiles = [];
  selectedPeople = [];
  document.getElementById('mem-titulo').value = '';
  document.getElementById('mem-desc').value = '';
  document.getElementById('mem-decada').value = '';
  document.getElementById('mem-fecha').value = '';
  document.getElementById('mem-lugar').value = '';
  document.getElementById('file-preview').innerHTML = '';
  document.getElementById('nuevo-title').textContent = 'Nuevo recuerdo';
}

// ── EDIT MEMORY ───────────────────────────────────────────────
async function editMemory(id) {
  closeModal();
  const m = allMemories.find(x=>x.id===id);
  if (!m) return;

  editingMemoryId = id;
  pendingFiles = [];

  document.getElementById('mem-titulo').value = m.titulo || '';
  document.getElementById('mem-desc').value   = m.descripcion || '';
  document.getElementById('mem-decada').value  = m.decada || '';
  document.getElementById('mem-fecha').value   = m.fecha_aprox || '';
  document.getElementById('mem-lugar').value   = m.lugar || '';
  document.getElementById('nuevo-title').textContent = 'Editar recuerdo';

  // Load existing people selection
  try {
    const links = await supa('GET', `/recuerdos_personas?recuerdo_id=eq.${id}&select=persona_id`);
    selectedPeople = (links||[]).map(l=>l.persona_id);
  } catch(e){}

  goTo('nuevo');
}

// ── DELETE MEMORY ─────────────────────────────────────────────
async function confirmDelete(id) {
  if (!confirm('¿Eliminar este recuerdo? Esta acción no se puede deshacer.')) return;
  try {
    await supa('DELETE', `/recuerdos?id=eq.${id}`);
    closeModal();
    toast('🗑️ Recuerdo eliminado', 'info');
    allMemories = allMemories.filter(m=>m.id!==id);
    allArchivos = allArchivos.filter(a=>a.recuerdo_id!==id);
    filterMemories();
  } catch(e) {
    toast('Error eliminando: '+e.message, 'error');
  }
}

// ── PERSONAS ──────────────────────────────────────────────────
async function loadPersonas() {
  document.getElementById('personas-grid').innerHTML = '<div class="loading"><div class="spinner"></div> Cargando...</div>';
  try {
    const personas = await supa('GET', '/personas?select=*&order=nombre');
    allPersonas = personas || [];
    renderPersonas();
  } catch(e) {
    toast('Error: '+e.message, 'error');
  }
}

function renderPersonas() {
  const grid = document.getElementById('personas-grid');
  if (!allPersonas.length) {
    grid.innerHTML = `<div class="empty-state">
      <div class="empty-state-icon">👥</div>
      <h3>Sin personas</h3>
      <p>Añade a las personas que aparecen en tus recuerdos</p>
    </div>`;
    return;
  }
  grid.innerHTML = allPersonas.map(p => {
    const count = allArchivos.filter(a => {
      // simplified: just use memory count
      return false; // We'd need join for this
    }).length;
    return `<div class="persona-card">
      <div class="persona-avatar">
        ${p.foto_url ? `<img src="${p.foto_url}" alt="${p.nombre}">` : '👤'}
      </div>
      <div class="persona-name">${p.nombre}</div>
      ${p.descripcion ? `<div class="persona-desc">${p.descripcion}</div>` : ''}
      <div class="persona-actions">
        <button class="btn btn-secondary btn-sm" onclick="editPersona('${p.id}')">✏️ Editar</button>
        <button class="btn btn-danger btn-sm" onclick="deletePersona('${p.id}')">🗑️</button>
      </div>
    </div>`;
  }).join('');
}

function handlePersonaFoto(files) {
  if (!files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    pendingPersonaFoto = { file: files[0], preview: e.target.result };
    document.getElementById('per-foto-preview').innerHTML =
      `<img src="${e.target.result}" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--accent2);">`;
  };
  reader.readAsDataURL(files[0]);
}

async function savePersona() {
  const nombre = document.getElementById('per-nombre').value.trim();
  if (!nombre) { toast('El nombre es obligatorio', 'error'); return; }

  const btn = document.getElementById('save-persona-btn');
  btn.disabled = true;
  btn.textContent = '⏳ Guardando...';

  try {
    let foto_url = null;
    if (pendingPersonaFoto) {
      foto_url = await uploadFile(pendingPersonaFoto.file, 'personas/');
    }

    const data = {
      nombre,
      descripcion: document.getElementById('per-desc').value.trim() || null,
    };
    if (foto_url) data.foto_url = foto_url;

    if (editingPersonaId) {
      await supa('PATCH', `/personas?id=eq.${editingPersonaId}`, data);
      toast('✅ Persona actualizada', 'success');
    } else {
      await supa('POST', '/personas', data);
      toast('✅ Persona añadida', 'success');
    }

    resetPersonaForm();
    goTo('personas');
  } catch(e) {
    toast('Error: '+e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = '💾 Guardar persona';
  }
}

function editPersona(id) {
  const p = allPersonas.find(x=>x.id===id);
  if (!p) return;
  editingPersonaId = id;
  document.getElementById('per-nombre').value = p.nombre || '';
  document.getElementById('per-desc').value   = p.descripcion || '';
  if (p.foto_url) {
    document.getElementById('per-foto-preview').innerHTML =
      `<img src="${p.foto_url}" style="width:80px;height:80px;border-radius:50%;object-fit:cover;border:2px solid var(--accent2);">`;
  }
  document.getElementById('persona-form-title').textContent = 'Editar persona';
  goTo('nueva-persona');
}

async function deletePersona(id) {
  if (!confirm('¿Eliminar esta persona?')) return;
  try {
    await supa('DELETE', `/personas?id=eq.${id}`);
    allPersonas = allPersonas.filter(p=>p.id!==id);
    renderPersonas();
    toast('🗑️ Persona eliminada', 'info');
  } catch(e) {
    toast('Error: '+e.message, 'error');
  }
}

function resetPersonaForm() {
  editingPersonaId = null;
  pendingPersonaFoto = null;
  document.getElementById('per-nombre').value = '';
  document.getElementById('per-desc').value = '';
  document.getElementById('per-foto-preview').innerHTML = '';
  document.getElementById('persona-form-title').textContent = 'Nueva persona';
}

// ── PEOPLE SELECTOR IN FORM ───────────────────────────────────
async function loadPeopleSelectorInForm() {
  try {
    if (!allPersonas.length) {
      const p = await supa('GET', '/personas?select=*&order=nombre');
      allPersonas = p || [];
    }
    const container = document.getElementById('people-selector');
    if (!allPersonas.length) {
      container.innerHTML = `<span style="color:var(--text2);font-size:0.9rem;">Primero añade personas desde el menú 👥</span>`;
      return;
    }
    container.innerHTML = allPersonas.map(p => `
      <div class="person-chip ${selectedPeople.includes(p.id)?'selected':''}" onclick="togglePerson('${p.id}', this)">
        ${p.foto_url ? `<img src="${p.foto_url}" style="width:24px;height:24px;border-radius:50%;object-fit:cover;">` : '👤'}
        ${p.nombre}
      </div>
    `).join('');
  } catch(e) {}
}

function togglePerson(id, el) {
  if (selectedPeople.includes(id)) {
    selectedPeople = selectedPeople.filter(x=>x!==id);
    el.classList.remove('selected');
  } else {
    selectedPeople.push(id);
    el.classList.add('selected');
  }
}

// ── INIT ──────────────────────────────────────────────────────
loadHome();
</script>
</body>
</html>
